#!/usr/bin/env bash
# =============================================================================
# Script Name: ipkg
# Description: Interactive package browser — fuzzy-find to install or remove
#              packages. alt+i: install mode, alt+r: remove mode.
# Author: Juan Garcia (arpatek)
# Created: 2026-05-15
# Version: 2.0
# =============================================================================

# ──[ Bash Version Check ]──────────────────────────────────────────────────────
if ((BASH_VERSINFO[0] < 4)); then
  printf "ipkg requires bash 4 or higher (detected: %s)\n" "$BASH_VERSION" >&2
  exit 1
fi

set -eo pipefail

# ──[ Error Trap ]──────────────────────────────────────────────────────────────
trap 'printf "\n%s Something went wrong.\n" "$(FAILED)"' ERR

# ──[ Paths ]───────────────────────────────────────────────────────────────────
DOTFILES_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# ──[ Shared Utilities ]────────────────────────────────────────────────────────
source "$DOTFILES_DIR/lib.sh"

# ──[ Dependency Check ]────────────────────────────────────────────────────────
if ! command -v fzf >/dev/null 2>&1; then
  printf "%s fzf is required but not installed\n" "$(FAILED)" >&2
  exit 1
fi

# ──[ Package Manager Detection ]───────────────────────────────────────────────
PKG_MGR=""
for pm in nala apt dnf pacman yum zypper apk; do
  if command -v "$pm" >/dev/null 2>&1; then
    PKG_MGR="$pm"
    break
  fi
done

if [[ -z "$PKG_MGR" ]]; then
  printf "%s No supported package manager found\n" "$(FAILED)" >&2
  exit 1
fi

# ──[ Per-manager Commands ]────────────────────────────────────────────────────
case "$PKG_MGR" in
  pacman)
    LIST_INSTALL='pacman -Slq 2>/dev/null'
    LIST_REMOVE='pacman -Qqe 2>/dev/null'
    PREVIEW_INSTALL='pacman -Sii {2} 2>/dev/null'
    PREVIEW_REMOVE='pacman -Qi {2} 2>/dev/null'
    INSTALL_CMD="sudo pacman -S --noconfirm"
    REMOVE_CMD="sudo pacman -Rns --noconfirm"
    ;;
  nala | apt)
    LIST_INSTALL='apt-cache pkgnames 2>/dev/null | sort'
    LIST_REMOVE='apt list --installed 2>/dev/null | awk -F/ '\''NR>1{print $1}'\'' | sort'
    PREVIEW_INSTALL='apt-cache show {2} 2>/dev/null | head -60'
    PREVIEW_REMOVE='dpkg -s {2} 2>/dev/null | head -40'
    INSTALL_CMD="sudo $PKG_MGR install -y"
    REMOVE_CMD="sudo $PKG_MGR remove -y"
    ;;
  dnf | yum)
    LIST_INSTALL="$PKG_MGR repoquery --available --quiet 2>/dev/null | sort -u"
    LIST_REMOVE="rpm -qa --qf '%{NAME}\n' 2>/dev/null | sort -u"
    PREVIEW_INSTALL="$PKG_MGR info {2} 2>/dev/null"
    PREVIEW_REMOVE="$PKG_MGR info {2} 2>/dev/null"
    INSTALL_CMD="sudo $PKG_MGR install -y"
    REMOVE_CMD="sudo $PKG_MGR remove -y"
    ;;
  zypper)
    LIST_INSTALL="zypper packages --not-installed-only 2>/dev/null | awk -F'|' 'NR>2{gsub(/ /,\"\",\$3); print \$3}' | sort -u"
    LIST_REMOVE="zypper packages --installed-only 2>/dev/null | awk -F'|' 'NR>2{gsub(/ /,\"\",\$3); print \$3}' | sort -u"
    PREVIEW_INSTALL='zypper info {2} 2>/dev/null'
    PREVIEW_REMOVE='zypper info {2} 2>/dev/null'
    INSTALL_CMD="sudo zypper install -y"
    REMOVE_CMD="sudo zypper remove -y"
    ;;
  apk)
    LIST_INSTALL='apk search --quiet 2>/dev/null | sort'
    LIST_REMOVE='apk info 2>/dev/null | sort'
    PREVIEW_INSTALL='apk info -a {2} 2>/dev/null'
    PREVIEW_REMOVE='apk info -a {2} 2>/dev/null'
    INSTALL_CMD="sudo apk add"
    REMOVE_CMD="sudo apk del"
    ;;
esac

# ──[ List Scripts ]────────────────────────────────────────────────────────────
# fzf reload binds run in a subshell that has no access to shell functions or
# variables from this script. Writing the list commands to temp executables
# lets the bind strings call them directly by path with no variable expansion.
INSTALL_SCRIPT=$(mktemp)
REMOVE_SCRIPT=$(mktemp)
trap 'rm -f "$INSTALL_SCRIPT" "$REMOVE_SCRIPT"' EXIT

printf "#!/usr/bin/env bash\n%s | sed 's|^|install |'\n" "$LIST_INSTALL" > "$INSTALL_SCRIPT"
printf "#!/usr/bin/env bash\n%s | sed 's|^|remove |'\n"  "$LIST_REMOVE"  > "$REMOVE_SCRIPT"
chmod +x "$INSTALL_SCRIPT" "$REMOVE_SCRIPT"

# ──[ Interactive Browser ]─────────────────────────────────────────────────────
fzf_args=(
  --multi
  --prompt '[INSTALL] > '
  --header "[$PKG_MGR] alt+r: remove mode  alt+i: install mode  tab: multi-select"
  --preview "$PREVIEW_INSTALL"
  --preview-label " Package Info "
  --preview-label-pos 'bottom'
  --preview-window 'down:60%:wrap'
  --color 'pointer:green,marker:green'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --bind "alt-r:reload($REMOVE_SCRIPT)+change-prompt([REMOVE] > )+change-preview($PREVIEW_REMOVE)+change-header([$PKG_MGR] alt+i: install mode  tab: multi-select)"
  --bind "alt-i:reload($INSTALL_SCRIPT)+change-prompt([INSTALL] > )+change-preview($PREVIEW_INSTALL)+change-header([$PKG_MGR] alt+r: remove mode  tab: multi-select)"
)

selections=$("$INSTALL_SCRIPT" | fzf "${fzf_args[@]}" || true)

[[ -z "$selections" ]] && exit 0

# ──[ Apply ]───────────────────────────────────────────────────────────────────
install_pkgs=()
remove_pkgs=()

while IFS=' ' read -r action name; do
  [[ -z "$name" ]] && continue
  case "$action" in
    install) install_pkgs+=("$name") ;;
    remove)  remove_pkgs+=("$name") ;;
  esac
done <<< "$selections"

cache_sudo

if (( ${#install_pkgs[@]} > 0 )); then
  printf "%s Installing: %s\n" "$(BANNER)" "${install_pkgs[*]}"
  $INSTALL_CMD "${install_pkgs[@]}"
fi

if (( ${#remove_pkgs[@]} > 0 )); then
  printf "%s Removing: %s\n" "$(BANNER)" "${remove_pkgs[*]}"
  $REMOVE_CMD "${remove_pkgs[@]}"
fi

printf "%s Done\n" "$(COMPLETE)"
